rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    function isValidProduct() {
      return request.resource.data.keys().hasAll([
        'slug',
        'name',
        'description',
        'category',
        'price',
        'colors',
        'sizes',
        'images',
        'thumbnail',
        'stock',
        'featured',
        'newArrival',
        'material',
        'specifications',
        'createdAt',
        'updatedAt'
      ])
      && request.resource.data.slug is string
      && request.resource.data.name is string
      && request.resource.data.description is string
      && request.resource.data.category in ['heels', 'flats', 'sandals', 'loafers', 'sneakers']
      && request.resource.data.price is number
      && request.resource.data.colors is list
      && request.resource.data.sizes is list
      && request.resource.data.images is list
      && request.resource.data.thumbnail is string
      && request.resource.data.stock is int
      && request.resource.data.featured is bool
      && request.resource.data.newArrival is bool;
    }

    function isValidCategory() {
      return request.resource.data.keys().hasAll(['name', 'slug', 'image'])
      && request.resource.data.name is string
      && request.resource.data.slug in ['heels', 'flats', 'sandals', 'loafers', 'sneakers']
      && request.resource.data.image is string;
    }

    function isValidTestimonial() {
      return request.resource.data.keys().hasAll(['customerName', 'city', 'rating', 'review', 'image'])
      && request.resource.data.customerName is string
      && request.resource.data.city is string
      && request.resource.data.rating is int
      && request.resource.data.rating >= 1
      && request.resource.data.rating <= 5
      && request.resource.data.review is string
      && request.resource.data.image is string;
    }

    function isValidBanner() {
      return request.resource.data.keys().hasAll(['headline', 'subheadline', 'image', 'ctaLabel', 'ctaHref'])
      && request.resource.data.headline is string
      && request.resource.data.subheadline is string
      && request.resource.data.image is string
      && request.resource.data.ctaLabel is string
      && request.resource.data.ctaHref is string;
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidProduct();
      allow delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidCategory();
      allow delete: if isAdmin();
    }

    match /testimonials/{testimonialId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidTestimonial();
      allow delete: if isAdmin();
    }

    match /banners/{bannerId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidBanner();
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
